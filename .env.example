# .env.example
# Copy this file to .env and fill in your paths before running docker compose.
#
#   cp .env.example .env
#   # Edit .env …
#   docker compose --profile setup run download_weights
#   docker compose up boxer

# ── Required ──────────────────────────────────────────────────────────────────
# Root folder of your Agisoft Metashape export.
# Must contain cameras.xml and (optionally) dense.ply + images/.
METASHAPE_DIR=/path/to/metashape_export

# ── Optional ──────────────────────────────────────────────────────────────────
# Where pipeline outputs (CSV, PLY, mask overlays) are written.
OUTPUT_DIR=./output

# Directory where SAM3 + Boxer weights are stored (auto-downloaded on first run).
CKPT_DIR=./ckpts

# Comma-separated list of SAM3 text prompts.
# Examples:
#   PROMPTS=coral
#   PROMPTS=coral,algae,rubble,sand
#   PROMPTS="brain coral,staghorn coral,table coral,bleached coral"
PROMPTS=coral

# SAM3 inference mode.
#   image  – independent per-frame detection (default, faster)
#   video  – temporally consistent instance IDs across frames (recommended
#            for Metashape sequences with >70% image overlap)
SAM3_MODE=image
